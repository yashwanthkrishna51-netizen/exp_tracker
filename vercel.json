{
  "version": 2,
  "buildCommand": "node build.js",
  "builds": [
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "GH_OWNER": "@gh-owner",
    "GH_REPO": "@gh-repo",
    "GH_TOKEN": "@gh-token",
    "GH_BRANCH": "@gh-branch",
    "GH_PATH": "@gh-path"
  }
}
